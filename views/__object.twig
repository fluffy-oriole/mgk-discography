{% extends "__layout.twig" %}
{% block content %}
<h1>{{ title }}</h1>
<div class="container mt-3">
    <ul class="nav nav-pills">
        <li class="nav-item">
            <a class="nav-link {{ is_image ? 'active' }}" aria-current="page" href="/{{ url_title }}/image">Картинка</a>
        </li>
        <li class="nav-item">
            <a class="nav-link {{ is_info ? 'active' }}" aria-current="page" href="/{{ url_title }}/info">Описание</a>
        </li>
    </ul>
</div>

<div class="container mt-3 p-3" style="border: 1px solid grey;">
    {% block objectContent %}{% endblock %}
</div>

{% endblock %}